# Copy this file to .env and fill in your keys
# Never commit .env to GitHub

# --- LLM Provider ---
# Options: "groq" or "openrouter"
LLM_PROVIDER=groq

# --- Groq API (free tier) ---
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- OpenRouter API (alternative free models) ---
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Model Selection ---
# Groq models:       llama3-8b-8192 | mixtral-8x7b-32768 | llama3-70b-8192
# OpenRouter models: meta-llama/llama-3.1-8b-instruct:free | mistralai/mistral-7b-instruct:free
LLM_MODEL=llama3-8b-8192

# --- Browser Settings ---
# true = you see the browser window (recommended during dev)
# false = headless, no window (use for production)
BROWSER_HEADLESS=false

# --- Proxy (leave blank during MVP, fill when client needs it) ---
PROXY_ENABLED=false
PROXY_URL=
